{
  "manifest_version": 3,
  "name": "Family Biz Football",
  "short_name": "FBL",
  "version": "1.1.0",
  "description": "Connect your ESPN Fantasy league to familybizfootball.com. Syncs league data directly from your browser.",
  "permissions": ["cookies", "activeTab", "storage"],
  "host_permissions": [
    "https://*.espn.com/*",
    "https://familybizfootball.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://fantasy.espn.com/*"],
      "js": ["espn-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
