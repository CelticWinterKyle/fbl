{
  "functions": {
    "app/api/analyze-matchup/route.ts": {
      "maxDuration": 30
    },
    "app/api/leagues/data/route.ts": {
      "maxDuration": 20
    },
    "app/api/roster/[teamKey]/route.ts": {
      "maxDuration": 20
    },
    "app/api/yahoo/callback/route.ts": {
      "maxDuration": 15
    },
    "app/api/cron/refresh-leagues/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/espn-keepalive/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/push-dispatch/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/kv-migrate/route.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-leagues",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/espn-keepalive",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/push-dispatch",
      "schedule": "*/5 * * * *"
    }
  ]
}