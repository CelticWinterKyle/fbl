{
  "functions": {
    "app/api/analyze-matchup/route.ts": { "maxDuration": 30 },
    "app/api/leagues/data/route.ts": { "maxDuration": 20 },
    "app/api/roster/[teamKey]/route.ts": { "maxDuration": 20 },
    "app/api/yahoo/callback/route.ts": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
