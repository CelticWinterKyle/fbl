# ─── Copy this file to .env.local and fill in your values ───────────────────

# ── Yahoo Fantasy OAuth (required for Yahoo leagues) ─────────────────────────
# Create an app at: https://developer.yahoo.com/apps/create/
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
# Full callback URL registered in your Yahoo app (must match exactly)
# e.g. http://localhost:3000/api/yahoo/callback  or  https://yourdomain.vercel.app/api/yahoo/callback
YAHOO_REDIRECT_URI=

# ── OpenAI (required for AI matchup analysis) ────────────────────────────────
OPENAI_API_KEY=

# ── Vercel KV (required in production for token storage + rate limiting) ──────
# Automatically injected by Vercel when you add a KV database to the project.
# In development, file-based storage is used (lib/yahoo-users/).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Cookie security ───────────────────────────────────────────────────────────
# Any random 32+ char secret used to HMAC-sign the fbl_uid session cookie.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Optional: expose debug routes (never set to 1 in production) ─────────────
# DEBUG_ROUTES=1

# ── Optional: show advanced Yahoo league key entry in header ──────────────────
# NEXT_PUBLIC_SHOW_ADVANCED=1
