# ─── Copy this file to .env.local and fill in your values ───────────────────

# ── Clerk Authentication (required) ──────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Where the custom sign-in/sign-up pages live
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Post-auth redirect targets (Clerk v5+ / Core 2 names — the old AFTER_SIGN_*_URL
# vars are IGNORED on @clerk/nextjs v7). These are env-level fallbacks; the
# <SignIn>/<SignUp> components also set fallbackRedirectUrl directly in code.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/welcome

# ── Yahoo Fantasy OAuth (required for Yahoo leagues) ─────────────────────────
# Create an app at: https://developer.yahoo.com/apps/create/
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
# Full callback URL registered in your Yahoo app (must match exactly)
# e.g. http://localhost:3000/api/yahoo/callback  or  https://yourdomain.vercel.app/api/yahoo/callback
YAHOO_REDIRECT_URI=

# ── OpenAI (required for AI matchup analysis) ────────────────────────────────
OPENAI_API_KEY=

# ── Vercel KV (required in production for token storage + rate limiting) ──────
# Automatically injected by Vercel when you add a KV database to the project.
# In development, file-based storage is used (lib/yahoo-users/).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Relay / token signing secret ──────────────────────────────────────────────
# Any random 32+ char secret. Used to HMAC-sign the browser-extension ESPN relay
# token AND to derive the at-rest encryption key for stored ESPN cookies.
# REQUIRED in production — if unset, extension ESPN sync (private leagues) fails.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Resend (transactional email: ESPN setup handoff) ─────────────────────────
# Optional — without it the "Email me the setup link" button reports an error
# but everything else works. Domain must be verified in Resend (leagueblitz.app).
RESEND_API_KEY=

# ── Admin dashboard ──────────────────────────────────────────────────────────
# Set to your Clerk user ID to access /admin
ADMIN_USER_ID=

# ── Optional: expose debug routes (never set to 1 in production) ─────────────
# DEBUG_ROUTES=1

# ── Optional: show advanced Yahoo league key entry in header ──────────────────
# NEXT_PUBLIC_SHOW_ADVANCED=1
